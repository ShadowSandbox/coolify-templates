---
import { DeploymentTabs, type DeploymentInfo } from './deployment-tabs';

interface Props {
  services: { name: string; image: string }[];
  deployment: DeploymentInfo;
  logo: string;
  logoBg: string;
}

const { services, deployment, logo, logoBg } = Astro.props;

// Best-effort brand icons for well-known companion services.
const KNOWN_ICONS: Record<string, string> = {
  postgresql: 'postgresql',
  postgres: 'postgresql',
  db: 'postgresql',
  mysql: 'mysql',
  mariadb: 'mariadb',
  redis: 'redis',
  clickhouse: 'clickhouse',
  mongodb: 'mongodb',
  kafka: 'apachekafka',
  kong: 'kong',
  elasticsearch: 'elasticsearch',
};

function serviceLogo(name: string, index: number): string | null {
  if (index === 0) return logo;
  const slug = KNOWN_ICONS[name.toLowerCase()];
  return slug ? `https://cdn.simpleicons.org/${slug}` : null;
}

const cards = services
  .map((service, index) => ({
    ...service,
    logo: serviceLogo(service.name, index),
    logoBg: index === 0 ? logoBg : '#ffffff',
    // Dummy wiring: volumes belong to the primary container for now.
    volumes: index === 0 ? deployment.volumes : [],
  }))
  .sort((a, b) => a.volumes.length - b.volumes.length);

const solo = cards.length === 1;
---

<div class="flex flex-col gap-5">
  <div
    class="rounded-xl border border-fd-border px-6 py-10 [background-image:radial-gradient(circle,rgb(0_0_0/0.1)_1px,transparent_1px)] [background-size:18px_18px] sm:py-12 dark:[background-image:radial-gradient(circle,rgb(255_255_255/0.08)_1px,transparent_1px)]"
  >
    <div
      class={solo
        ? 'flex justify-center'
        : `mx-auto grid w-full gap-4 sm:grid-cols-2 ${
            cards.length >= 3 ? 'max-w-4xl md:grid-cols-3' : 'max-w-xl'
          } items-start`}
    >
      {
        cards.map((card) => (
          <div class={`flex flex-col rounded-xl border border-fd-border bg-fd-card p-1.5 ${solo ? 'w-52' : ''}`}>
            <div
              class={`rounded-[9px] border border-fd-border bg-fd-background shadow-[0_1px_4px_rgba(0,0,0,0.08)] ${
                solo
                  ? 'flex flex-1 flex-col items-center justify-center gap-2.5 px-5 py-8 text-center'
                  : 'flex items-center gap-3 p-3.5'
              }`}
            >
              {card.logo ? (
                <span
                  class={`flex shrink-0 items-center justify-center rounded-md border border-black/10 dark:border-transparent ${
                    solo ? 'size-11 p-1.5' : 'size-8 p-1'
                  }`}
                  style={`background-color: ${card.logoBg}`}
                >
                  <img src={card.logo} alt="" class="size-full object-contain" />
                </span>
              ) : (
                <span class="flex size-8 shrink-0 items-center justify-center rounded-md bg-fd-muted">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="size-4.5 text-fd-muted-foreground"
                  >
                    <path
                      d="m21 8-9-5-9 5v8l9 5 9-5zM3 8l9 5m0 0 9-5m-9 5v9"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
              )}
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold">{card.name}</p>
                <p class="truncate text-[13px] text-fd-muted-foreground">{card.image}</p>
              </div>
            </div>
            {card.volumes.length > 0 && (
              <div class={`flex flex-col gap-1 px-2.5 pb-1 pt-2 ${solo ? 'items-center' : ''}`}>
                {card.volumes.length === 1 ? card.volumes.map((volume) => (
                  <span class="truncate font-mono text-xs text-fd-muted-foreground">
                    {volume.path}
                  </span>
                )) : (
                  <span class="text-xs text-fd-muted-foreground">
                    {card.volumes.length} persistent volumes
                  </span>
                )}
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>

  <DeploymentTabs services={services} deployment={deployment} client:load />
</div>
