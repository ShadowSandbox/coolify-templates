---
import { ClientRouter } from 'astro:transitions';
import { withBase } from '@/lib/templates';
import '@/styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <script is:inline>
      const applyTheme = () => {
        const stored = localStorage.getItem('theme');
        // Dark is the default; light is an explicit choice.
        const dark = stored ? stored === 'dark' : true;
        document.documentElement.classList.toggle('dark', dark);
      };
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
      document.addEventListener('click', (e) => {
        if (e.target instanceof Element && e.target.closest('#theme-toggle')) {
          const dark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', dark ? 'dark' : 'light');
        }
      });
    </script>
    <ClientRouter />
  </head>
  <body
    class="relative flex flex-col min-h-screen bg-fd-background text-fd-foreground"
    transition:persist
    transition:animate="none"
    transition:name="page-layout"
  >
    <header class="sticky top-0 z-40 border-b border-fd-border bg-fd-background/80 backdrop-blur">
      <div class="mx-auto flex h-14 w-full max-w-7xl items-center justify-between px-4 sm:px-6">
        <a href={withBase('/')} class="flex items-center gap-2 font-semibold">
          <img src={withBase('/coolify.svg')} alt="" class="size-6" />
          <span>Coolify <span class="text-fd-muted-foreground font-normal">Templates</span></span>
        </a>
        <nav class="flex items-center gap-4 text-sm text-fd-muted-foreground">
          <a href="https://coolify.io/docs" class="hover:text-fd-foreground transition-colors">Docs</a>
          <a
            href="https://github.com/coollabsio/coolify"
            class="hover:text-fd-foreground transition-colors">GitHub</a
          >
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle theme"
            class="rounded-md p-1.5 transition-colors hover:text-fd-foreground"
          >
            <svg
              class="hidden size-4 dark:block"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path
                d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"
              ></path>
            </svg>
            <svg
              class="size-4 dark:hidden"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>
    <slot />
  </body>
</html>
