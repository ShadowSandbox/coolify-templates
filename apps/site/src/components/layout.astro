---
import { ClientRouter } from 'astro:transitions';
import { withBase } from '@/lib/templates';
import '@/styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <ClientRouter />
  </head>
  <body
    class="dark flex flex-col min-h-screen bg-fd-background text-fd-foreground"
    transition:persist
    transition:animate="none"
    transition:name="page-layout"
  >
    <header class="sticky top-0 z-40 border-b border-fd-border bg-fd-background/80 backdrop-blur">
      <div class="mx-auto flex h-14 w-full max-w-7xl items-center justify-between px-4 sm:px-6">
        <a href={withBase('/')} class="flex items-center gap-2 font-semibold">
          <img src={withBase('/coolify.svg')} alt="" class="size-6" />
          <span>Coolify <span class="text-fd-muted-foreground font-normal">Templates</span></span>
        </a>
        <nav class="flex items-center gap-4 text-sm text-fd-muted-foreground">
          <a href="https://coolify.io/docs" class="hover:text-fd-foreground transition-colors">Docs</a>
          <a
            href="https://github.com/coollabsio/coolify"
            class="hover:text-fd-foreground transition-colors">GitHub</a
          >
        </nav>
      </div>
    </header>
    <slot />
    <footer class="mt-auto border-t border-fd-border">
      <div
        class="mx-auto flex w-full max-w-7xl flex-col gap-2 px-4 py-8 text-sm text-fd-muted-foreground sm:flex-row sm:items-center sm:justify-between sm:px-6"
      >
        <p>Open-source, one-click service templates for Coolify.</p>
        <p>
          Maintained by the <a href="https://coolify.io" class="underline hover:text-fd-foreground"
            >Coolify</a
          > community.
        </p>
      </div>
    </footer>
  </body>
</html>
