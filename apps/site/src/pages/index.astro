---
import Layout from '@/components/layout.astro';
import { TemplateBrowser } from '@/components/template-browser';
import { getTemplates, toCard } from '@/lib/templates';

const templates = (await getTemplates()).map(toCard);
---

<Layout>
  <title>Coolify Templates</title>
  <meta
    name="description"
    content="One-click, open-source service templates for your Coolify instance."
  />
  <main class="relative mx-auto w-full max-w-7xl flex-1 px-4 sm:px-6">
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-[34rem] w-screen -translate-x-1/2 bg-[radial-gradient(circle_at_50%_38%,rgba(134,79,252,0.11),rgba(134,79,252,0.04)_40%,transparent_62%)] opacity-50 dark:opacity-100"
      aria-hidden="true"
    >
    </div>
    <section class="pb-10 pt-32 text-center sm:pt-40">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">What would you like to deploy?</h1>
    </section>
    <section class="pb-24">
      <TemplateBrowser templates={templates} client:load />
    </section>
  </main>
</Layout>
