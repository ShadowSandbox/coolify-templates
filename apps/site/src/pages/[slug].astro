---
import { render } from 'astro:content';
import defaultMdxComponents from 'fumadocs-ui/mdx';
import type { TOCItemType } from 'fumadocs-core/toc';
import Layout from '@/components/layout.astro';
import DeploymentSpec from '@/components/deployment-spec.astro';
import TemplateInfo from '@/components/template-info.astro';
import { FeatureTabs } from '@/components/feature-tabs';
import { TemplateGallery } from '@/components/template-gallery';
import { Toc } from '@/components/toc';
import {
  deployUrl,
  getTemplates,
  templateUrl,
  withBase,
  type Template,
} from '@/lib/templates';

interface Props {
  template: Template;
}

export async function getStaticPaths() {
  return (await getTemplates()).map((template) => ({
    params: { slug: template.id },
    props: { template },
  }));
}

const { template } = Astro.props;
const {
  title,
  description,
  logo,
  logoBg,
  categories,
  services,
  screenshots,
  by,
  stats,
  links,
  features,
  deployment,
} = template.data;

const serviceLinks = [
  { label: 'Official website', href: links.website, icon: 'globe' },
  { label: 'Documentation', href: links.docs, icon: 'book' },
  { label: 'Source repository', href: links.github, icon: 'github' },
].filter((l): l is { label: string; href: string; icon: string } => Boolean(l.href));
const { Content, headings } = await render(template);
const ogImage = withBase(`/og/${template.id}/image.webp`);

const related = (await getTemplates())
  .filter((t) => t.id !== template.id && t.data.categories.some((c) => categories.includes(c)))
  .slice(0, 3);

const galleryImages = screenshots.map((shot) => ({ src: withBase(shot.src), alt: shot.alt }));

const toc: TOCItemType[] = headings.map((heading) => ({
  depth: heading.depth,
  title: heading.text,
  url: `#${heading.slug}`,
}));
toc.push({ depth: 2, title: 'Features', url: '#features' });
toc.push({ depth: 2, title: 'What gets deployed', url: '#what-gets-deployed' });
---

<Layout>
  <title>{title} — Coolify Templates</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <div class="border-b border-fd-border bg-fd-card/50">
    <div class="mx-auto w-full max-w-7xl px-4 py-5 sm:px-6">
      <a
        href={withBase('/')}
        class="inline-flex items-center gap-2 text-sm text-fd-muted-foreground transition-colors hover:text-fd-foreground"
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-4"
        >
          <path d="M19 12H5m0 0 6 6m-6-6 6-6"></path>
        </svg>
        Back to Templates
      </a>

      <div class="mt-3 flex flex-wrap items-center justify-between gap-4">
        <div class="flex min-w-0 items-center gap-3.5">
          <div
            class="flex size-9 shrink-0 items-center justify-center rounded-lg border border-black/10 p-1.5 dark:border-transparent"
            style={`background-color: ${logoBg}`}
          >
            <img src={logo} alt="" class="size-full object-contain" />
          </div>
          <h1 class="truncate text-[28px] font-semibold tracking-tight">{title}</h1>
        </div>
        <div class="flex shrink-0 items-center gap-2">
          <a
            href={deployUrl(template.id)}
            class="inline-flex items-center gap-2 rounded-lg bg-[#864ffc] px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-[#7440e0]"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="size-4"
            >
              <path d="M13 2 3 14h7l-1 8 10-12h-7z" stroke-linejoin="round"></path>
            </svg>
            Deploy to Coolify
          </a>
          {
            serviceLinks.map((link) => (
              <a
                href={link.href}
                title={link.label}
                aria-label={link.label}
                class="grid size-9 place-items-center rounded-lg border border-fd-border text-fd-muted-foreground transition-colors hover:bg-fd-accent hover:text-fd-foreground"
              >
                {link.icon === 'globe' && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    class="size-4"
                  >
                    <circle cx="12" cy="12" r="9" />
                    <path d="M3 12h18M12 3a15 15 0 0 1 0 18 15 15 0 0 1 0-18" />
                  </svg>
                )}
                {link.icon === 'book' && (
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="size-4"
                  >
                    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20V4a2 2 0 0 0-2-2H6.5A2.5 2.5 0 0 0 4 4.5v15A2.5 2.5 0 0 0 6.5 22H20v-2.5H6.5a1 1 0 0 1 0-2" />
                  </svg>
                )}
                {link.icon === 'github' && (
                  <svg viewBox="0 0 24 24" fill="currentColor" class="size-4">
                    <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.17c-3.2.7-3.87-1.37-3.87-1.37-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.02 1.75 2.69 1.25 3.34.95.11-.74.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.7 5.38-5.27 5.67.41.36.78 1.06.78 2.14v3.17c0 .3.21.67.8.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
  <main class="mx-auto w-full max-w-7xl flex-1 px-4 py-12 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_220px]">
      <div class="flex flex-col gap-14">
        <div class="flex flex-col gap-6">
          {
            galleryImages.length > 0 && (
              <div>
                <div
                  id="gallery-fallback"
                  class="flex aspect-video items-center justify-center rounded-xl border border-fd-border bg-fd-card"
                  aria-hidden="true"
                >
                  <div class="size-8 animate-spin rounded-full border-2 border-fd-border border-t-[#864ffc]" />
                </div>
                <TemplateGallery images={galleryImages} client:only="react" />
              </div>
            )
          }

          <TemplateInfo by={by} stats={stats} />
        </div>

        <section class="prose max-w-none">
          <Content components={{ ...defaultMdxComponents }} />
        </section>

        <section>
          <h2 id="features" class="mb-5 scroll-mt-24 text-2xl font-semibold">Features</h2>
          <FeatureTabs
            application={features.application}
            template={features.template}
            client:load
          />
        </section>

        <section>
          <h2 id="what-gets-deployed" class="mb-5 scroll-mt-24 text-2xl font-semibold">
            What gets deployed
          </h2>
          <DeploymentSpec services={services} deployment={deployment} logo={logo} logoBg={logoBg} />
        </section>
      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-20">
          <Toc items={toc} client:load />
        </div>
      </aside>
    </div>

    {
      related.length > 0 && (
        <section class="mt-20 border-t border-fd-border pt-10">
          <div class="mb-6 flex items-center justify-between">
            <h2 class="text-xl font-semibold">You might also like</h2>
            <a
              href={withBase('/')}
              class="text-sm text-fd-muted-foreground transition-colors hover:text-fd-foreground"
            >
              Browse all templates →
            </a>
          </div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((t) => (
              <a
                href={templateUrl(t.id)}
                class="group flex flex-col gap-3 rounded-xl border border-fd-border bg-fd-card p-5 transition-colors hover:border-[#864ffc]/40"
              >
                <span
                  class="flex size-10 items-center justify-center rounded-[10px] border border-black/10 p-1.5 dark:border-transparent"
                  style={`background-color: ${t.data.logoBg}`}
                >
                  <img src={t.data.logo} alt="" class="size-full object-contain" />
                </span>
                <div>
                  <h3 class="font-medium">{t.data.title}</h3>
                  <p class="mt-1 line-clamp-2 text-sm text-fd-muted-foreground">
                    {t.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>
